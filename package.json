  },
  "keywords": [
    "mcp",
    "hashlock",
    "htlc",
    "otc",
    "claude",
    "ai-agent",
    "atomic-swap"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/Hashlock-Tech/hashlock-mcp"
  },
  "engines": {
    "node": ">=18"
